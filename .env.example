# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Application
PORT=8080
APP_BASE_URL=https://example.com

# PostgreSQL
DB_NAME=mainwetten
DB_URL=jdbc:postgresql://localhost:5432/mainwetten
DB_USER=mainwetten
DB_PASSWORD=change-me

# Outgoing email
MAIL_FROM=no-reply@example.com
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLED=true
MAIL_STARTTLS_REQUIRED=true

# Generate a long random value for production.
REMEMBER_ME_KEY=replace-with-a-long-random-secret

# Legal pages
LEGAL_FULL_NAME=Vorname Nachname
LEGAL_STREET=Straße und Hausnummer
LEGAL_POSTAL_CODE=00000
LEGAL_CITY=Ort
LEGAL_COUNTRY=Deutschland
LEGAL_EMAIL=kontakt@mainwetten.de
LEGAL_SUPERVISORY_AUTHORITY_NAME=Zuständige Landesdatenschutzbehörde
LEGAL_SUPERVISORY_AUTHORITY_ADDRESS=Vollständige Anschrift der Behörde